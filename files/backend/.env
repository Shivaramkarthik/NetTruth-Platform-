# NetTruth Backend - Environment Configuration
# External config only - no source code modified

APP_NAME=NetTruth
APP_VERSION=1.0.0
DEBUG=true

# Database (SQLite - no external DB required)
DATABASE_URL=sqlite+aiosqlite:///./nettruth.db

# Security Keys
SECRET_KEY=nettruth-local-secret-key-2024-abcdef123456
JWT_SECRET_KEY=nettruth-jwt-secret-key-2024-abcdef123456
JWT_ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=30

# InfluxDB (optional - used for time-series metrics)
INFLUXDB_URL=http://localhost:8086
INFLUXDB_TOKEN=local-dev-token
INFLUXDB_ORG=nettruth
INFLUXDB_BUCKET=network_metrics

# ML Model Paths
ML_MODEL_PATH=./ml_models

# Privacy Settings
ANONYMIZATION_SALT=nettruth-anonymization-salt-2024
DIFFERENTIAL_PRIVACY_EPSILON=1.0

# Network Testing Intervals
SPEED_TEST_INTERVAL=300
PING_INTERVAL=60
